# PHProxy
#
# If you renamed index.php to proxy.php (or anything else), change the
# `index.php` references below to match.

<IfModule mod_rewrite.c>
    RewriteEngine On

    # Backward compat: the old settings page lived at edit.php. Bounce
    # to the entry form (the Headers tab is its replacement).
    RewriteRule ^edit\.php$ index.php [L,QSA]

    # Don't rewrite real files or directories
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d

    # Path-style URLs (#24):
    #   /http(s):/target/... -> /index.php/http(s):/target/...
    RewriteRule ^(https?:/.*)$ index.php/$1 [L,QSA]
</IfModule>
